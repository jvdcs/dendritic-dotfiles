# Fit document to window width on startup
set adjust-open width

# Zero spacing between pages
set page-padding 0

set window-width 3000
set window-height 3000

# zathurarc keybindings

map r reload
map d navigate next
map u navigate previous
map l navigate next
map h navigate previous
map <C-s> toggle_statusbar
map <A-z> toggle_statusbar
